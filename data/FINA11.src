&ACCESS RVP
&REL 143
DEF FINA11()
   DECL E6axis PX1 ;shengming px1 bianliang
   
   GLOBAL INTERRUPT DECL 3 WHEN $STOPMESS==TRUE DO IR_STOPM ( ) 
   INTERRUPT ON 3
   BAS (#INITMOV,0)
   BAS (#VEL_PTP,20)
   BAS (#ACC_PTP,20)
   $APO.CDIS = 100.0
   $VEL.CP = 0.5
   $ADVANCE=5
   $TOOL={X 0, Y 0, Z 319.5, A 0, B 0, C 0}
   $BASE={X 1708, Y 89, Z 1050, A 180, B 0, C 180}
   PTP {A1 -30.000, A2 -120.000, A3 120.000, A4 0.000, A5 0.000, A6 0.000, E1 0, E2 0, E3 0, E4 0, E5 0, E6 0}
   $async_EX_AX_DECOUPLE='b0001' ;dianji qu ouhe
   $AXIS_ACT.E1=0 ;bianmqi qingling 
   WAIT SEC 1 ; yanshi 1s
   $async_EX_AX_DECOUPLE='b0000' ;dianji ouhe
   HALT
   $advance=5
   $VEL.CP=0.167
   $APO.CDIS = 0
   CONTINUE ;dongzuo lianguan 
   ;IF SELT_MODE==1 THEN
   PTP {A1 5, A2 -84.46, A3 114.11, A4 59.82, A5 -48.27, A6 67.3, E1 0, E2 0, E3 0, E4 0, E5 0, E6 0} ;fenxian weizhi 
   PTP {A1 5, A2 -84.46, A3 114.11, A4 59.82, A5 -48.27, A6 67.3, E1 0, E2 0, E3 0, E4 0, E5 0, E6 0} ;fenxian weizhi 
   HALT ;zanting 
   $APO.CDIS = 100 ;yuanhuaguodu 
   PX1=$AXIS_ACT ;jiang dang qian jiaodu fuzhi gei px1
   NUM_TURN=1  ;zhuan jiao du ji shu bian liang 
   CONTINUE
   $VEL.CP=0.167
   FOR NUM_TURN=1 TO 30  ;jiang NUM_TURN bianliang xunhuan 10ci 
      PX1.E1=PX1.E1+120.0
      PTP PX1 C_DIS ;
   ENDFOR
   ;zan ting
   HALT
